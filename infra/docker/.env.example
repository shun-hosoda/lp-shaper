############################################################
# Supabase OSS セルフホスト — 環境変数サンプル
# 実際の値は .env にコピーして設定する（.env は .gitignore済み）
############################################################

# PostgreSQL
# ローカル開発用デフォルト値（本番環境では必ず変更すること）
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_DB=postgres

# JWT シークレット（下記の ANON_KEY / SERVICE_ROLE_KEY はこの値で署名済み）
# ⚠️ 本番環境では必ず変更すること
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
# アクセストークン有効期限（秒）— ADR-003: 15分
JWT_EXPIRY=900

# Supabase API キー（JWT_SECRET に対応した開発用固定値）
# 本番環境では supabase/docker/utils/generate-keys.sh で再生成すること
# anon key: JWT payload { role: "anon", iss: "supabase-demo" }
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
# service_role key: JWT payload { role: "service_role", iss: "supabase-demo" }
# ⚠️ NEXT_PUBLIC_ プレフィックス厳禁。Server Action / Route Handler のみで使用
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# GoTrue (Supabase Auth) 設定
SITE_URL=http://localhost:3100
ADDITIONAL_REDIRECT_URLS=http://localhost:3100/auth/callback,http://localhost:3100/auth/confirm
API_EXTERNAL_URL=http://localhost:8100

# Google OAuth（Google Cloud Console で取得）
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
GOTRUE_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=http://localhost:8100/auth/v1/callback

# メール送信（開発環境は inbucket を使用）
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_SENDER_NAME=common-auth-to-c

# Next.js からの接続情報（frontend/.env.local にも設定する）
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8100
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
